# -----------------------------------------------------------------------------
# Environment configuration template.
# Copy this file to `.env` and fill in real values. `.env` is git-ignored so
# no credentials are ever committed (see assignment: "No hardcoded credentials").
# -----------------------------------------------------------------------------

# App
APP_NAME=Personal Finance Manager
APP_ENV=development

# API (used later when a backend is wired in; safe placeholders for now)
API_BASE_URL=https://api.example.com
API_TIMEOUT_MS=30000

# Firebase / Google Sign-In (bonus features - fill when enabling)
GOOGLE_WEB_CLIENT_ID=
